#!/usr/bin/env bash
# ui — dispatcher for the UI reference project.
#
# No args (or `ui tui` / `ui web`) opens the top chooser TUI — a tiny
# Storm menu that asks which of the four views you want, then launches
# it. The terminal showcase itself is a *second* chooser: pick which of
# the seven inspiration-based demos to open. Skip the menus with the
# explicit arg pair:
#
#   ui                                  → top chooser menu
#   ui tui                              → top chooser menu
#   ui web                              → top chooser menu
#   ui tui showcase                     → showcase demo picker
#   ui tui showcase <demo>              → that demo directly
#                                         (feature|logbook|bios95|
#                                          brutalist|flightdeck|
#                                          posting|oxide|dock)
#   ui tui style                        → terminal style guide
#   ui web showcase                     → web showcase (http://localhost:3000)
#   ui web style                        → web style guide (?mode=style)
#
# Back-nav convention: any terminal TUI that exits with code 99 means
# "go back to the previous menu". Demos → showcase picker → top menu.

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
TERMINAL_DIR="$ROOT/src/terminal"

BACK_CODE=99

usage() {
  cat <<EOF
ui — living style reference

Usage:
  ui                           open top chooser menu
  ui tui | ui web              open top chooser menu
  ui tui showcase              pick a terminal demo (7 options)
  ui tui showcase <demo>       open demo directly
                               demos: feature, logbook, bios95,
                                      brutalist, flightdeck,
                                      posting, oxide, dock
  ui tui style                 terminal style guide
  ui web showcase              web showcase  (http://localhost:3000)
  ui web style                 web style guide (http://localhost:3000/?mode=style)
  ui help                      show this message
EOF
}

install_terminal_deps() {
  if [ ! -d "$TERMINAL_DIR/node_modules" ]; then
    echo "→ installing terminal deps with bun"
    (cd "$TERMINAL_DIR" && bun install)
  fi
}

install_web_deps() {
  if [ ! -d "$ROOT/node_modules" ]; then
    echo "→ installing web deps with bun"
    (cd "$ROOT" && bun install)
  fi
}

# Run a demo. rc=99 → back to showcase picker. rc=0 → quit entirely.
run_terminal_demo() {
  install_terminal_deps
  local rc=0
  local file
  case "$1" in
    feature)    file="showcase/feature.tsx" ;;
    logbook)    file="showcase/logbook.tsx" ;;
    bios95)     file="showcase/bios95.tsx" ;;
    brutalist)  file="showcase/brutalist.tsx" ;;
    flightdeck) file="showcase/flightdeck.tsx" ;;
    posting)    file="showcase/posting.tsx" ;;
    oxide)      file="showcase/oxide.tsx" ;;
    dock)       file="showcase/dock.tsx" ;;
    *) echo "unknown demo: $1" >&2; exit 1 ;;
  esac
  (cd "$TERMINAL_DIR" && bun run "$file") 2>/dev/null || rc=$?
  if [ "$rc" -eq "$BACK_CODE" ]; then run_showcase_picker; fi
}

# Showcase demo picker. rc=30–36 → demo; rc=99 → back to top menu.
run_showcase_picker() {
  install_terminal_deps
  local rc=0
  (cd "$TERMINAL_DIR" && bun run showcase/app.tsx) 2>/dev/null || rc=$?
  case "$rc" in
    30) run_terminal_demo feature ;;
    31) run_terminal_demo logbook ;;
    32) run_terminal_demo bios95 ;;
    33) run_terminal_demo brutalist ;;
    34) run_terminal_demo flightdeck ;;
    35) run_terminal_demo posting ;;
    36) run_terminal_demo oxide ;;
    37) run_terminal_demo dock ;;
    "$BACK_CODE") run_top_menu ;;
    *)  exit 0 ;;
  esac
}

# Terminal style guide. rc=99 → back to top menu.
run_terminal_style() {
  install_terminal_deps
  local rc=0
  (cd "$TERMINAL_DIR" && bun run style/app.tsx) 2>/dev/null || rc=$?
  if [ "$rc" -eq "$BACK_CODE" ]; then run_top_menu; fi
}

run_web() {
  local mode="${1:-showcase}"
  install_web_deps
  cd "$ROOT"
  if [ "$mode" = "style" ]; then
    echo "→ style guide: http://localhost:3000/?mode=style"
  else
    echo "→ showcase:    http://localhost:3000/"
  fi
  exec bun --hot server.ts
}

# Top chooser menu — exits with 10/11/20/21 for terminal/web × showcase/style.
run_top_menu() {
  install_terminal_deps
  local rc=0
  (cd "$TERMINAL_DIR" && bun run menu.tsx) 2>/dev/null || rc=$?
  case "$rc" in
    10) run_showcase_picker ;;
    11) run_terminal_style ;;
    20) run_web showcase ;;
    21) run_web style ;;
    *)  exit 0 ;;
  esac
}

cmd="${1:-menu}"
case "$cmd" in
  menu|"") run_top_menu ;;
  tui)
    sub="${2:-}"
    case "$sub" in
      "")            run_top_menu ;;
      showcase)
        sub2="${3:-}"
        case "$sub2" in
          "") run_showcase_picker ;;
          feature|logbook|bios95|brutalist|flightdeck|posting|oxide)
            run_terminal_demo "$sub2" ;;
          *) echo "unknown showcase demo: $sub2" >&2; exit 1 ;;
        esac
        ;;
      style)         run_terminal_style ;;
      *) echo "unknown tui arg: $sub (try: showcase | style)" >&2; exit 1 ;;
    esac
    ;;
  web)
    sub="${2:-}"
    case "$sub" in
      "")            run_top_menu ;;
      showcase)      run_web showcase ;;
      style)         run_web style ;;
      *) echo "unknown web arg: $sub (try: showcase | style)" >&2; exit 1 ;;
    esac
    ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
