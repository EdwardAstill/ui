#!/usr/bin/env bash
# ui — launch the browser style reference.

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

usage() {
  cat <<EOF
ui — living browser style reference

Usage:
  ui                 start the main web site at http://localhost:3000/
  ui help            show this message
EOF
}

install_web_deps() {
  if [ ! -d "$ROOT/node_modules" ]; then
    echo "→ installing web deps with bun"
    (cd "$ROOT" && bun install)
  fi
}

run_web() {
  install_web_deps
  cd "$ROOT"
  echo "→ web site: http://localhost:3000/"
  exec bun --hot server.ts
}

case "${1:-}" in
  "") run_web ;;
  help | -h | --help) usage ;;
  *) usage; exit 1 ;;
esac
